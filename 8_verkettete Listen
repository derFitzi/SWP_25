import random

class ListElement:
    def __init__(self, value: int):
        self.value = value
        self.next = None

class LinkedList:
    def __init__(self):
        self.head = None

    def hinten_hinzufuegen(self, value: int):
        new_elem = ListElement(value)
        if self.head is None:
            self.head = new_elem
            return

        current = self.head
        while current.next is not None:
            current = current.next

        current.next = new_elem

    def __len__(self):
        count = 0
        current = self.head
        while current is not None:
            count += 1
            current = current.next
        return count

    def __iter__(self):
        current = self.head
        while current is not None:
            yield current.value
            current = current.next

    def __str__(self):
        string =""
        string += "["
        for value in self:
            string += str(value)
            string += ","
        string = string[:-1]
        string += "]"
        return string

def main():
    liste = LinkedList()

    for _ in range(10):
        liste.hinten_hinzufuegen(random.randint(1, 100))

    print("Alle Elemente:")
    print(liste)

    print("Länge der Liste:", len(liste))


if __name__ == "__main__":
    main()
