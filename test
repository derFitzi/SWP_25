    void muellErkennen() {
      // Nicht prüfen wenn System beschäftigt ist
      if (klappenStatus != KLAPPEN_GESCHLOSSEN && klappenStatus != KLAPPEN_FERTIG) {
        return;
      }
      if (!schlittenInInitialPosition) {
        return;
      }
      
      // In Intervallen messen
      if (kalibriert && millis() - letzteMessung >= messIntervall) {
        letzteMessung = millis();
        distanz = entfernung(trg1, ech1);
        Serial.print("Aktueller Wert: "); Serial.println(distanz);

        // Starke Abweichung vom Mittelwert? -> Müll erkannt!
        if (distanz > 0 && 
            abs(distanz - mittelwert) > abweichungsschwelle && 
            !warteAufEndschalter && 
            !warteAufInitialPosition) {
          processTrashDetection();  // Verarbeitung starten
        }
      }
    }

    // === MÜLL VERARBEITUNG ===
