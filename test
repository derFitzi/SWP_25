    // === KI PREDICTION ANALYSIEREN ===
    // Parst JSON vom Raspberry Pi und gibt beste Müllart zurück
    String normalizePredictionLabel(String rawLabel) {
      // hätte man auch in der muellartPin Funktion machen können, dann aber nicht abwärtskompatibel mit den alten Testversionen
      rawLabel.trim();
      rawLabel.toLowerCase();
      if (rawLabel.length() == 0) return "";
      if (rawLabel == "plastic" || rawLabel == "kunststoff") return "KUNSTSTOFF";
      if (rawLabel == "paper" || rawLabel == "papier") return "PAPIER";
      if (rawLabel == "waste" || rawLabel == "restmuell" || rawLabel == "restmull") return "RESTMUELL";
      if (rawLabel == "metal" || rawLabel == "metall") return "KUNSTSTOFF"; // Metall und Kunststoff in den gleichen Behälter
      return "";
    }

    String useFallbackPrediction(const String& message) {
      Serial.println(message);
      lastPredictionResult = message;
      predictionWasInvalid = true;
      currentPredictionJson = "";
      return "KUNSTSTOFF"; // FALLBACK später ändern auf RESTMUELL
    }

    String analyzeTrashTypeFromServer() {
      if (currentPredictionJson == "") {
        return useFallbackPrediction("Prediction fehlerhaft - verwende RESTMUELL");
      }
      Serial.println(currentPredictionJson);

      StaticJsonDocument<4096> predDoc;
      DeserializationError error = deserializeJson(predDoc, currentPredictionJson);
      if (error) {
        return useFallbackPrediction("JSON parse error: " + String(error.c_str()));
      }

      JsonArray imagePredictions = predDoc.as<JsonArray>();
      if (imagePredictions.isNull()) {
        return useFallbackPrediction("Prediction JSON kein Array - verwende RESTMUELL");
      }

      float maxProbability = -1.0f;
      String bestRawLabel = "";

      for (JsonVariant imageVariant : imagePredictions) {
        if (!imageVariant.is<JsonArray>()) {
          continue;
        }
        for (JsonVariant predictionVariant : imageVariant.as<JsonArray>()) {
          if (!predictionVariant.is<JsonArray>()) {
            continue;
          }
          JsonArray entry = predictionVariant.as<JsonArray>();
          if (entry.size() < 2) {
            continue;
          }
          const char* label = entry[0].as<const char*>();
          if (!label) {
            continue;
          }
          float probability = entry[1].as<float>();
          if (probability > maxProbability) {
            maxProbability = probability;
            bestRawLabel = label;
          }
        }
      }
      //Lösung basiert auf: https://arduinojson.org/v7/tutorial/deserialization/

      if (bestRawLabel == "") {
        return useFallbackPrediction("Keine gültigen Predictions - verwende RESTMUELL");
      }

      String normalizedLabel = normalizePredictionLabel(bestRawLabel);
      if (normalizedLabel == "") {
        return useFallbackPrediction("Unbekannte Müllart erkannt: " + bestRawLabel);
      }

      Serial.print("Erkannte Müllart vom Raspberry: ");
      Serial.print(normalizedLabel);
      Serial.print(" (Wahrscheinlichkeit: ");
      Serial.print(maxProbability * 100, 2); // auf 2 Stellen gerundet
      Serial.println("%)");

      lastPredictionResult = normalizedLabel + " (" + String(maxProbability * 100, 2) + "%)";
      predictionWasInvalid = false;
      currentPredictionJson = "";
      return normalizedLabel;
    }

    // === WARTUNGSKLAPPE HANDLER ===
    // Empfängt Updates der Wartungsklappensteuerung
    void handleWartungsklappe() {
      if (!server.hasArg("plain")) {
        server.send(400, "application/json", "{\"error\":\"Missing JSON body\"}");
        return;
      }
      
      String body = server.arg("plain");
      Serial.println("Wartungsklappe JSON empfangen: " + body);
      
      StaticJsonDocument<200> doc;
      DeserializationError error = deserializeJson(doc, body);
      
      if (error) {
        Serial.print("JSON Parse Fehler: "); Serial.println(error.c_str());
        server.send(400, "application/json", "{\"error\":\"Invalid JSON\"}");
        return;
      }
      
      String status = doc["status"];
      bool led = doc["led"];
      bool reed = doc["reed"];
      int servo = doc["servo"];
      
      // Wartung wird geöffnet
      if (status == "offen") {
        Serial.println("WARTUNG: System wird SOFORT blockiert - Alle Motoren stoppen");
        
        wartungsklappePausiert = true;
        wartungsklappeLetzterStatus = true;
        
        // Laufende Tasks beenden
        if (currentTaskName != "") {
          taskBeenden();
          Serial.println("Task unterbrochen: " + currentTaskName);
        }
        
        // ALLE Motoren SOFORT stoppen!
        motorA_stop();
        motorB_stop();
        schlitten_stop();
        
        Serial.println("WARTUNG AKTIV - Alle Motoren gestoppt");
      } 
      // Wartung wird geschlossen
      else if (status == "geschlossen") {
        Serial.println("WARTUNG BEENDET - System wird freigegeben");
        
        wartungsklappePausiert = false;
        wartungsklappeLetzterStatus = false;
        
        // Fehler zurücksetzen
        taskTimeoutError = false;
        timeoutErrorMessage = "";
        
        // Wenn Schlitten in Bewegung war, weiter fahren
        if (warteAufEndschalter || warteAufInitialPosition) {
          Serial.println("   Setze unterbrochene Schlittenfahrt fort...");
          restartSchlittenIfNeeded();
        } else {
          Serial.println("   Keine unterbrochene Fahrt - System bereit");
        }
      }
      server.send(200, "application/json", "{\"status\":\"ok\",\"received\":true}");
    }

