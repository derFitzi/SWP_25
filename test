    // === PIN SETUP ===
    void pinSetup() {
      // Ultraschall Sensoren
      pinMode(trg1, OUTPUT); pinMode(ech1, INPUT);
      pinMode(trg2, OUTPUT); pinMode(ech2, INPUT);
      pinMode(trg3, OUTPUT); pinMode(ech3, INPUT);
      pinMode(trg4, OUTPUT); pinMode(ech4, INPUT);

      // Klappen Motoren
      pinMode(IN1, OUTPUT); pinMode(IN2, OUTPUT);
      pinMode(IN3, OUTPUT); pinMode(IN4, OUTPUT);

      // Reed-Sensoren
      pinMode(reedPin1, INPUT); pinMode(reedPin2, INPUT);
      pinMode(reedPin3, INPUT); pinMode(reedPin4, INPUT);

      // Schlitten Motor
      pinMode(schlittenMotor_IN, OUTPUT);
      digitalWrite(schlittenMotor_IN, HIGH); 
      pinMode(schlittenMotor_IN1_PWM, OUTPUT);
      pinMode(schlittenMotor_IN2_PWM, OUTPUT);
      ledcSetup(SCHLITTEN_PWM_CHANNEL_IN1, SCHLITTEN_PWM_FREQ, SCHLITTEN_PWM_RESOLUTION);
      ledcSetup(SCHLITTEN_PWM_CHANNEL_IN2, SCHLITTEN_PWM_FREQ, SCHLITTEN_PWM_RESOLUTION);
      ledcAttachPin(schlittenMotor_IN1_PWM, SCHLITTEN_PWM_CHANNEL_IN1);
      ledcAttachPin(schlittenMotor_IN2_PWM, SCHLITTEN_PWM_CHANNEL_IN2);
      ledcWrite(SCHLITTEN_PWM_CHANNEL_IN1, 0);
      ledcWrite(SCHLITTEN_PWM_CHANNEL_IN2, 0);

      // Lichtschranken
      pinMode(restmuellSensor, INPUT);
      pinMode(kunststoffmuellSensor, INPUT);
      pinMode(papiermuellSensor, INPUT);
    }

    // === WIFI SETUP ===
    // Verbindet mit WLAN und startet Server
    void wifiSetup() {
      Serial.println("\n---- WiFi Setup");
      
      WiFi.mode(WIFI_STA);  // Station Mode (kein AP)
      
      // Statische IP setzen
      if (!WiFi.config(local_IP, gateway, subnet, primaryDNS, secondaryDNS)) {
        Serial.println("IP Setup Fehler");
      } else {
        Serial.println("IP gesetzt");
        Serial.print("  IP: "); Serial.println(local_IP);
        Serial.print("  Gateway: "); Serial.println(gateway);
      }
      
      // Mit WLAN verbinden
      WiFi.begin(wifi_ssid, wifi_password);
      Serial.print("Verbinde mit "); Serial.print(wifi_ssid);
      
      // Warte bis verbunden (max 10 sekunden)
      unsigned long startVersuch = millis();
      while (WiFi.status() != WL_CONNECTED && millis() - startVersuch < 10000) {
        delay(500);
        Serial.print(".");
      }
      
      // Wenn erfolgreich verbunden
      if (WiFi.status() == WL_CONNECTED) {
        Serial.println();
        Serial.println("WiFi OK");
        Serial.print("  IP: "); Serial.println(WiFi.localIP());
        Serial.print("  Gateway: "); Serial.println(WiFi.gatewayIP());
      } else {
        Serial.println("\n WiFi Fehler");
        return;
      }
      serverSetup();  // HTTP Server starten
    }

    // === OTA SETUP ===
    // Aktiviert Over-The-Air Updates via WiFi
    void otaSetup() {
      ArduinoOTA.setHostname(OTA_Hostname.c_str());
      ArduinoOTA.setPassword(OTA_Password.c_str());
      
      // Beim Update-Start
      ArduinoOTA.onStart([]() {
        motorA_stop();           // Alle Motoren stoppen
        motorB_stop();
        schlitten_stop();
        ledSetzen(CRGB::Orange); // LED Orange = Update läuft
        Serial.println("OTA Start");
      });
      
      // Wenn Update fertig
      ArduinoOTA.onEnd([]() {
        Serial.println("\nOTA fertig");
        ledSetzen(CRGB::Green);
        delay(1000);
      });
      
      // Während Update läuft
      ArduinoOTA.onProgress([](unsigned int fortschritt, unsigned int gesamt) {
        unsigned int prozent = (fortschritt / (gesamt / 100));
        Serial.printf("OTA: %u%%\r", prozent);
        
        // LED blinken als Fortschrittsanzeige
        static unsigned long letztesBlinken = 0;
        if (millis() - letztesBlinken > 200) {
          letztesBlinken = millis();
          static bool ledZustand = false;
          ledZustand = !ledZustand;
          ledSetzen(ledZustand ? CRGB::Red : CRGB::Black);
        }
      });
      
      // Bei Fehler
      ArduinoOTA.onError([](ota_error_t fehler) {
        Serial.printf("OTA Fehler[%u]: ", fehler);
        if (fehler == OTA_AUTH_ERROR) Serial.println("Auth Failed");
        else if (fehler == OTA_BEGIN_ERROR) Serial.println("Begin Failed");
        else if (fehler == OTA_CONNECT_ERROR) Serial.println("Connect Failed");
        else if (fehler == OTA_RECEIVE_ERROR) Serial.println("Receive Failed");
        else if (fehler == OTA_END_ERROR) Serial.println("End Failed");
        
        ledSetzen(CRGB::Red);
        delay(2000);
        ledSetzen(CRGB::Black);
      });
      
      ArduinoOTA.begin();
      Serial.println(" OTA aktiv");
      Serial.print("  IP: "); Serial.println(WiFi.localIP());
      // Lösung basierend auf: https://github.com/espressif/arduino-esp32/blob/master/libraries/ArduinoOTA/examples/BasicOTA/BasicOTA.ino
    }

