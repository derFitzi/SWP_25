    // === TIMEOUT ÜBERWACHUNG ===
    // Damit das System nicht hängen bleibt
    // Startet Timer für einen Task
    void taskStarten(String taskName) {
      currentTaskStartTime = millis();
      currentTaskName = taskName;
      taskTimeoutError = false;
      timeoutErrorMessage = "";
      Serial.println("Start: " + taskName);
    }

    // Beendet aktuellen Task
    void taskBeenden() {
      if (currentTaskName != "") {
        unsigned long dauer = millis() - currentTaskStartTime;
        Serial.println("Ende: Task " + currentTaskName + " hat " + String(dauer) + "ms gedauert");
        currentTaskName = "";
        currentTaskStartTime = 0;
      }
    }

    // Prüft ob Task zu lange läuft
    void timeoutPruefen() {
      if (currentTaskName != "" && currentTaskStartTime > 0) {
        unsigned long dauer = millis() - currentTaskStartTime;
        if (dauer > MAX_TASK_TIMEOUT) {
          if (!taskTimeoutError) {  // Nur einmal melden
            taskTimeoutError = true;
            timeoutErrorMessage = "TIMEOUT: '" + currentTaskName + "' läuft " + 
                                String(dauer/1000) + " Sekunden";
            Serial.println(timeoutErrorMessage);
            timeoutRecovery();  // Automatischer Reset auf Startposition
          }
        }
      }
    }

    // === TIMEOUT RECOVERY ===
    // Bricht ab, schließt die Klappen und Fährt zurück zur Startposition
    void timeoutRecovery() {
      Serial.println("\nZEITÜBERSCHREITUNG: System wird resettet");
      
      // 1. Alle Motoren stoppen
      motorA_stop();
      motorB_stop();
      schlitten_stop();
      
      // 2. Status zurücksetzen
      klappenStatus = KLAPPEN_GESCHLOSSEN;
      warteAufEndschalter = false;
      warteAufInitialPosition = false;
      waitingForPrediction = false;
      currentPredictionJson = "";
      
      // 3. Task beenden
      taskBeenden();
      
      // 4. System zurück zur Startposition
      Serial.println("Fahre zurück zur Startposition");
      systemInStartpositionBringen();
      
      // 5. Fehler zurücksetzen
      taskTimeoutError = false;
      timeoutErrorMessage = "";
      
      Serial.println("System zurückgesetzt");
      Serial.println("Bereit für nächsten Einwurf");
    }


    // === SCHLITTEN SANFTANLAUF ===
    // Rampengesteuerte PWM-Ausgabe für den Schlittenmotor
    void schlittenPwmAusgabe(int duty, bool vorwaerts) {
      duty = constrain(duty, 0, schlittenMaxGeschwindigkeit);
      schlittenAktuellerDuty = duty;
      if (vorwaerts) {
        ledcWrite(SCHLITTEN_PWM_CHANNEL_IN1, duty);
        ledcWrite(SCHLITTEN_PWM_CHANNEL_IN2, 0);
      } else {
        ledcWrite(SCHLITTEN_PWM_CHANNEL_IN1, 0);
        ledcWrite(SCHLITTEN_PWM_CHANNEL_IN2, duty);
      }
    }

    void schlittenSanftStoppen() {
      const int decStep = max(1, schlittenMaxGeschwindigkeit / 25);
      while (schlittenAktuellerDuty > 0) {
        int nextDuty = max(0, schlittenAktuellerDuty - decStep);
        schlittenPwmAusgabe(nextDuty, schlittenRichtungVorwaerts);
        delay(5);
      }
      ledcWrite(SCHLITTEN_PWM_CHANNEL_IN1, 0);
      ledcWrite(SCHLITTEN_PWM_CHANNEL_IN2, 0);
      schlittenAktuellerDuty = 0;
    }

    void starteSchlittenRampe(bool vorwaerts) {
      schlittenRichtungVorwaerts = vorwaerts;
      schlittenRampenIndex = 0;
      schlittenLetzteRampeZeit = millis();
      schlittenMotorZustand = vorwaerts ? SCHLITTEN_VORWAERTS_RAMPE : SCHLITTEN_RUECKWAERTS_RAMPE;
      schlitten_in_bewegung = 1;
    }

    void schlittenRampeUpdate(unsigned long jetzt) {
      if (schlittenMotorZustand == SCHLITTEN_STOP) return;
      if (jetzt - schlittenLetzteRampeZeit < schlittenRampenIntervall) return;

      schlittenLetzteRampeZeit = jetzt;
      int pwmWert = schlittenMaxGeschwindigkeit;

      if (schlittenMotorZustand == SCHLITTEN_VORWAERTS_RAMPE || schlittenMotorZustand == SCHLITTEN_RUECKWAERTS_RAMPE) {
        pwmWert = map(schlittenRampenIndex, 0, schlittenRampenSchritte, 0, schlittenMaxGeschwindigkeit);
        schlittenRampenIndex++;

        if (schlittenRampenIndex > schlittenRampenSchritte) {
          schlittenMotorZustand = SCHLITTEN_LAUFEND;
          pwmWert = schlittenMaxGeschwindigkeit;
          Serial.println("Schlitten: Maximalgeschwindigkeit erreicht");
        }
      }

      schlittenPwmAusgabe(pwmWert, schlittenRichtungVorwaerts);
    }

    // === HAUPTPROGRAMM ===
    void loop() {
      server.handleClient();  // HTTP Anfragen bearbeiten
      ArduinoOTA.handle();    // OTA Updates prüfen
      
      timeoutPruefen();  // Timeout-Überwachung
      schlittenRampeUpdate(millis());  // PWM-Rampe aktualisieren
      
      // Alle 10 Sekunden WiFi-Verbindung prüfen
      static unsigned long letzterWifiCheck = 0;
      if (millis() - letzterWifiCheck >= 10000) {
        letzterWifiCheck = millis();
        if (WiFi.status() != WL_CONNECTED) {
          Serial.println(" WiFi verloren - versuche neu zu verbinden");
          WiFi.reconnect();
        }
      }
      
      // Bei Wartung: Nur Server-Anfragen, Rest stoppen
      if (wartungsklappePausiert) return;
      
      // Hauptfunktionen
      klappenVerarbeiten();  // Klappen State Machine
      muellErkennen();       // Ultraschall prüfen
      schlittenBewegen();    // Schlitten bewegen
    }

    // === ULTRASCHALLMESSUNG ===
    // Misst Entfernung mit Ultraschall-Sensor
    int entfernung(int trigPin, int echoPin) {
      digitalWrite(trigPin, LOW); 
      delayMicroseconds(2);
      digitalWrite(trigPin, HIGH); 
      delayMicroseconds(10);
      digitalWrite(trigPin, LOW);

      ultraschallDauer = pulseIn(echoPin, HIGH, 25000);
      if (ultraschallDauer == 0) return -1;  // Gibt -1 zurück wenn Messung fehlschlägt
      abstand = ultraschallDauer * 0.034 / 2;  // Umrechnung in cm
      return abstand;
    }

    // === BILD VON KAMERA HOLEN ===
    // Holt ein Foto von einer ESP32-CAM
    // Gibt Base64-kodierten String zurück
    String getCameraImage(const char* url) {
      // Prüfen ob Wartung aktiv
      if (wartungsklappePausiert) {
        Serial.println(" Wartung aktiv - keine Kamera-Abfrage");
        return "";
      }
      
      HTTPClient http;
      http.begin(url);
      http.setTimeout(10000);  // 10 Sekunden Timeout für Kamera
      int httpCode = http.GET();
      
      if (httpCode != 200) { 
        Serial.printf("Fehler bei %s: %d\n", url, httpCode); 
        http.end(); 
        return ""; 
      }
      
      WiFiClient* stream = http.getStreamPtr();
      int len = http.getSize(); 
      if (len <= 0) len = 50000;  // Fallback wenn Größe unbekannt
      
      // Weil das Bild früher manchmal zu groß für den RAM war
      size_t maxAlloc = ESP.getMaxAllocHeap();
      if (maxAlloc == 0) maxAlloc = ESP.getFreeHeap();
      if (len > static_cast<int>(maxAlloc - 2048)) {
        Serial.printf("Bild zu groß (%d Bytes > %d Bytes verfügbare Heap) - überspringe Kamera\n", len, static_cast<int>(maxAlloc - 2048));
        http.end();
        return "";
      }
      // Speicher für Bild reservieren
      uint8_t* buf = (uint8_t*)malloc(len);
      if (!buf) { 
        Serial.println("Nicht genug RAM für Bild"); 
        http.end(); 
        return ""; 
      }
      
      // Bild herunterladen und Base64 kodieren
      stream->readBytes(buf, len);
      String b64 = base64::encode(buf, len);
      free(buf);  // Speicher freigeben
      http.end();
      
      return b64;
      // Lösung basiert auf: https://github.com/espressif/arduino-esp32/blob/master/libraries/HTTPClient/examples/StreamHttpClient/StreamHttpClient.ino
    }

    // === MÜLLARTEN PIN ZUORDNUNG ===
    // Gibt Lichtschranken-Pin für Müllart zurück
    int muellartPin(String muellart) {
      if (muellart == "INITIAL") return restmuellSensor; // Initialposition nur noch Restmüllposition
      else if (muellart == "RESTMUELL") return restmuellSensor;
      else if (muellart == "PAPIER") return papiermuellSensor;
      else if (muellart == "KUNSTSTOFF") return kunststoffmuellSensor;
      return -1;  // Ungültige Müllart
    }

    bool lichtschrankeAktiv(int pin) {
      if (pin < 0) {
        return false;
      }

      if (!schlitten_in_bewegung) {
        return digitalRead(pin) == HIGH;
      }

      const unsigned long start = micros();
      while (micros() - start < LICHTSCHRANKEN_SAMPLING_DAUER_US) {
        if (digitalRead(pin) == HIGH) {
          return true;
        }
        delayMicroseconds(LICHTSCHRANKEN_SAMPLING_PAUSE_US);
      }
      return false;
    }

    bool obereEndposition(int s1, int s2, int s3, int s4) {
      return (s1 == HIGH && s2 == HIGH && s3 == HIGH && s4 == HIGH);
    }

    bool untereEndposition(int s1, int s2, int s3, int s4) {
      return (s1 == LOW && s2 == LOW && s3 == LOW && s4 == LOW);
    }

    // === KLAPPEN STATE MACHINE ===
    // Steuert beide Klappen
    // Läuft in loop() bis Status = FERTIG
    void KlappensteuerungNonBlocking() {
      // Alle Reed-Sensoren lesen
      int s1 = digitalRead(reedPin1);  // Motor A geschlossen
      int s2 = digitalRead(reedPin2);  // Motor A offen
      int s3 = digitalRead(reedPin3);  // Motor B geschlossen
      int s4 = digitalRead(reedPin4);  // Motor B offen

      Serial.printf("Reed: %d %d %d %d | Zustand: %d\n", s1, s2, s3, s4, static_cast<int>(klappenStatus));// Debug-Ausgabe
      // Spammt Serial Monitor ziemlich voll

      switch (klappenStatus) {
        case KLAPPEN_OEFFNEN:
          if (!untereEndposition(s1, s2, s3, s4)) {
            motorA_vorwaerts();
            motorB_vorwaerts();
          } else {
            motorA_stop();
            motorB_stop();
            motorA_fertig = true;
            motorB_fertig = true;
            klappenWarteStart = millis();
            klappenStatus = KLAPPEN_PAUSE_NACH_OEFFNEN;
            Serial.println("OFFEN erreicht - Pause nach Öffnen");
          }
          break;

        case KLAPPEN_PAUSE_NACH_OEFFNEN:
          if (millis() - klappenWarteStart >= KLAPPEN_WARTEZEIT) {
            klappenStatus = KLAPPEN_SCHLIESSEN;
            motorA_fertig = false;
            motorB_fertig = false;
            Serial.println("Pause vorbei - Klappen schließen");
          }
          break;

        case KLAPPEN_SCHLIESSEN:
          if (!obereEndposition(s1, s2, s3, s4)) {
            motorA_rueckwaerts();
            motorB_rueckwaerts();
          } else {
            klappenWarteStart = millis();
            motorA_fertig = true;
            motorB_fertig = true;
            klappenStatus = KLAPPEN_PAUSE_NACH_SCHLIESSEN;
            Serial.println("Geschlossen erreicht - 1 Sekunde Nachlauf");
          }
          break;

        case KLAPPEN_PAUSE_NACH_SCHLIESSEN:
          // Schlitten darf sich bewegen, Klappen schließen aber noch mehr für höhere Stabilität des Bodens
          if (millis() - klappenWarteStart < KLAPPEN_SCHLIESS_NACHLAUF) {
            motorA_rueckwaerts();
            motorB_rueckwaerts();
          } else {
            motorA_stop();
            motorB_stop();
            klappenStatus = KLAPPEN_FERTIG;
            Serial.println("Nachlauf beendet - Klappen fertig");
          }
          break;

        default:
          break;
      }
    }

