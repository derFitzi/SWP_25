// Parst JSON vom Raspberry Pi, gibt Label+Wahrscheinlichkeit als Struct zurück
struct PredictionResult {
  String label;
  float probability;
};

PredictionResult parseSinglePrediction(const String& predictionJson) {
  PredictionResult result = {"", -1.0f};

  if (predictionJson == "") return result;

  StaticJsonDocument<4096> predDoc;
  DeserializationError error = deserializeJson(predDoc, predictionJson);
  if (error) {
    Serial.println("JSON parse error: " + String(error.c_str()));
    return result;
  }

  JsonArray imagePredictions = predDoc.as<JsonArray>();
  if (imagePredictions.isNull()) {
    Serial.println("Prediction JSON kein Array");
    return result;
  }

  for (JsonVariant imageVariant : imagePredictions) {
    if (!imageVariant.is<JsonArray>()) continue;
    for (JsonVariant predictionVariant : imageVariant.as<JsonArray>()) {
      if (!predictionVariant.is<JsonArray>()) continue;
      JsonArray entry = predictionVariant.as<JsonArray>();
      if (entry.size() < 2) continue;
      const char* label = entry[0].as<const char*>();
      if (!label) continue;
      float probability = entry[1].as<float>();
      if (probability > result.probability) {
        result.probability = probability;
        result.label = label;
      }
    }
  }
  // Lösung basiert auf: https://arduinojson.org/v7/tutorial/deserialization/
  return result;
}

// Pro Kamera: Bild holen → an Raspberry senden → Prediction empfangen
// Am Ende wird die Prediction mit der höchsten Einzelwahrscheinlichkeit verwendet
bool uploadImagesToServer() {
  if (!ensureDeviceRegistered()) {
    Serial.println("Skipped Uploads, Gerät nicht registriert");
    return false;
  }

  taskStarten("Bilder einzeln uploaden zum Server");

  bool predictionReady = false;

  for (int i = 0; i < 3; i++) {

    // Wartung während Upload? -> Abbrechen
    if (wartungsklappePausiert) {
      Serial.println("Wartung aktiv während Kamera-Upload - breche ab");
      taskBeenden();
      return false;
    }

    // --- 1. Bild von Kamera holen ---
    Serial.println("Hole Bild von Kamera " + String(i + 1) + "...");
    String b64 = getCameraImage(camIPs[i]);
    b64.replace("\n", "");
    b64.replace("\r", "");
    b64.trim();

    if (b64.isEmpty()) {
      Serial.println("Kamera " + String(i + 1) + ": FEHLER/LEER - überspringe");
      continue;
    }
    Serial.println("Kamera " + String(i + 1) + ": OK (" + String(b64.length()) + " Zeichen)");

    // Nochmal Wartung prüfen vor dem Upload
    if (wartungsklappePausiert) {
      Serial.println("Wartung aktiv vor Upload Kamera " + String(i + 1) + " - breche ab");
      taskBeenden();
      return false;
    }

    // --- 2. JSON-Payload für dieses eine Bild bauen ---
    String jsonString;
    jsonString.reserve(b64.length() + 80);
    jsonString  = "{\"images\":[\"";
    jsonString += b64;
    jsonString += "\"],\"device_name\":\"";
    jsonString += apiDeviceName;
    jsonString += "\",\"save_images\":true}";

    Serial.printf("Kamera %d Payload: %u Zeichen\n", i + 1, jsonString.length());
    Serial.println("Payload Start -->");
    Serial.println(jsonString);
    Serial.println("<-- Payload Ende");

    // --- 3. An Raspberry Pi senden und Antwort empfangen ---
    HTTPClient http;
    http.begin(buildApiUrl("/api/images/predict"));
    http.addHeader("Content-Type", "application/json");
    http.addHeader("Content-Length", String(jsonString.length()));
    http.setTimeout(60000);
    http.useHTTP10(true);

    uint8_t* payloadPtr = const_cast<uint8_t*>(
      reinterpret_cast<const uint8_t*>(jsonString.c_str())
    );
    int httpCode = http.POST(payloadPtr, jsonString.length());

    if (httpCode != 200) {
      Serial.printf("Kamera %d Upload fehlgeschlagen: HTTP %d\n", i + 1, httpCode);
      http.end();
      continue;
    }

    String responseJson = http.getString();
    http.end();
    Serial.println("Kamera " + String(i + 1) + " Prediction empfangen");

    // --- 4. Beste Wahrscheinlichkeit aus diesem Response extrahieren ---
    PredictionResult result = parseSinglePrediction(responseJson);

    if (result.label != "" && result.probability >= 0.0f) {
      currentPredictionJson  = "[[[\"";
      currentPredictionJson += result.label;
      currentPredictionJson += "\",";
      currentPredictionJson += String(result.probability, 6);
      currentPredictionJson += "]]]";
      Serial.printf("Kamera %d Prediction akzeptiert: %s (%.2f%%)\n",
                    i + 1, result.label.c_str(), result.probability * 100);
      predictionReady = true;
      break; // nur ein Bild pro Upload verarbeiten
    }
  }

  taskBeenden();

  if (!predictionReady) {
    Serial.println("Keine gültige Prediction von keiner Kamera erhalten");
    currentPredictionJson = "";
    return false;
  }
  return true;
}

