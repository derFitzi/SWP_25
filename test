    // === KLAPPEN RESET-SCHLIESSEN ===
    // Zwingt Klappen zum Schließen
    void forceKlappenToClosedPosition() {
      Serial.println("Reset: Schließe alle Klappen...");
      
      bool motorA_geschlossen = (digitalRead(reedPin1) == HIGH);
      bool motorB_geschlossen = (digitalRead(reedPin3) == HIGH);
      
      if (motorA_geschlossen && motorB_geschlossen) {
        Serial.println("Klappen bereits geschlossen");
        return;
      }
      
      unsigned long resetStartTime = millis();
      const unsigned long RESET_TIMEOUT = 10000;
      
      // Blockiert, aber ok weil nur für Reset
      while ((!motorA_geschlossen || !motorB_geschlossen) && 
            (millis() - resetStartTime < RESET_TIMEOUT)) {
        
        // Motor A schließen
        if (!motorA_geschlossen) {
          if (digitalRead(reedPin1) == HIGH) {
            motorA_stop();
            motorA_geschlossen = true;
            Serial.println("  Motor A geschlossen");
          } else {
            digitalWrite(IN1, LOW);
            digitalWrite(IN2, HIGH);
          }
        }
        
        // Motor B schließen
        if (!motorB_geschlossen) {
          if (digitalRead(reedPin3) == HIGH) {
            motorB_stop();
            motorB_geschlossen = true;
            Serial.println("  Motor B geschlossen");
          } else {
            digitalWrite(IN3, LOW);
            digitalWrite(IN4, HIGH);
          }
        }
        delay(100);
      }
      
      motorA_stop(); // Für Sicherheit
      motorB_stop(); // Für Sicherheit
      
      if (motorA_geschlossen && motorB_geschlossen) {
        Serial.println("Alle Klappen wurden geschlossen");
      } else {
        Serial.println("Achtung: Reed-Sensoren nicht erreicht!");
      }
    }

    // === SCHLITTEN ZWANGS-RÜCKFAHRT ===
    // Zwingt Schlitten zur Initialposition zu fahren
    void forceSchlittenToInitialPosition() {
      Serial.println("Reset: Fahre Schlitten zur Initialposition...");
      
      bool initialPositionReached = lichtschrankeAktiv(restmuellSensor); // Initialposition = Restmüllposition
      
      if (initialPositionReached) {
        Serial.println("Schlitten bereits in Initialposition");
        schlittenInInitialPosition = true;
        return;
      }
      
      Serial.println("Starte Rückwärtsfahrt zur Initialposition...");
      
      unsigned long resetStartTime = millis();
      const unsigned long RESET_TIMEOUT = 15000;
 
      schlitten_rueckwaerts(); // Motor starten (mit Rampe)
      
      // Blockiert, aber ok weil nur für Reset
      while (!initialPositionReached && (millis() - resetStartTime < RESET_TIMEOUT)) {
        schlittenRampeUpdate(millis());
        if (lichtschrankeAktiv(restmuellSensor)) { // Initialposition = Restmüllposition
          initialPositionReached = true;
          Serial.println("Initialposition erreicht");
          }
        delay(50);
      }
      
      schlitten_stop();
      
      if (initialPositionReached) {
        Serial.println("Schlitten angekommen in Initialposition");
        schlittenInInitialPosition = true;
      } else {
        Serial.println("Achtung: Initialposition nicht erreicht!");
        schlittenInInitialPosition = false;
      }
    }

