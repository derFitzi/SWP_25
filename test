    // === ULTRASCHALL KALIBRIEREN ===
    // Misst 3 Sekunden lang Durchschnittswert vom leeren Fallschacht
    void ultraschallKalibrieren() {
      Serial.println("Starte Kalibrierung des Ultraschall-Fallschachts...");
      long summe = 0;
      int messungen = 0;
      unsigned long startZeit = millis();
      
      // 3 Sekunden messen
      while (millis() - startZeit < 3000) {
        distanz = entfernung(trg1, ech1);
        if (distanz > 0){ 
          summe += distanz; 
          messungen++; 
        }
        delay(50);
      }
      
      // Durchschnitt berechnen
      if (messungen > 0) {
        mittelwert = summe / messungen;
        kalibriert = true;
        Serial.print("Durchschnittlicher Wert: "); Serial.println(mittelwert);
      } else {
        Serial.println("Fehler: Kalibrierung fehlgeschlagen");
      }
    }

    // === DEVICE REGISTRIERUNG ===
    // Fragt die Geräte-Liste vom Server ab und liefert die ID zu diesem Gerät
    int fetchExistingDeviceId() {
      if (WiFi.status() != WL_CONNECTED) return -1;

      HTTPClient http;
      http.begin(buildApiUrl("/api/devices"));
      int code = http.GET();
      if (code != 200) {
        Serial.printf("Device list failed: HTTP %d\n", code);
        http.end();
        return -1;
      }

      DynamicJsonDocument doc(4096);
      DeserializationError err = deserializeJson(doc, http.getString());
      http.end();
      if (err) {
        Serial.printf("Device list parse error: %s\n", err.c_str());
        return -1;
      }

      for (JsonObject device : doc.as<JsonArray>()) {
        if (device["name"].as<String>() == apiDeviceName) {
          return device["id"] | -1;
        }
      }
      return -1;
  }

  // Erstellt Gerät auf Server und speichert ID
  bool createDeviceRecord() {
      if (WiFi.status() != WL_CONNECTED) return false;

      HTTPClient http;
      http.begin(buildApiUrl("/api/device/register"));
      http.addHeader("Content-Type", "application/json");

      StaticJsonDocument<512> body;
      body["device_name"] = apiDeviceName;
      body["location"] = apiDeviceLocation;

      String payload;
      serializeJson(body, payload);

      int code = http.POST(payload);
      if (code == 409) {
        Serial.println("Device bereits vorhanden");
        http.end();
        apiDeviceId = fetchExistingDeviceId(); // Id von bestehendem Gerät holen
        return apiDeviceId >= 0;
      }
      if (code != 201 && code != 200) {
        Serial.printf("Device Registrierung fehlgeschlagen: HTTP %d\n", code);
        http.end();
        return false;
      }

      DynamicJsonDocument doc(512);
      String response = http.getString();
      DeserializationError err = deserializeJson(doc, response);
      http.end();
      if (err) {
        Serial.printf("Device Registrierung Parse Fehler: %s\n", err.c_str());
        apiDeviceId = fetchExistingDeviceId();  // Id von bestehendem Gerät holen
        return apiDeviceId >= 0;
      }

      // ID aus Antwort extrahieren
      long resolvedId = -1;
      if (doc.containsKey("device_id")) {
        resolvedId = doc["device_id"].as<long>();
      } else if (doc.containsKey("id")) {
        resolvedId = doc["id"].as<long>();
      } else if (doc.containsKey("data")) {
        JsonVariant data = doc["data"];
        if (data.is<JsonObject>()) {
          JsonObject obj = data.as<JsonObject>();
          if (obj.containsKey("device_id")) {
            resolvedId = obj["device_id"].as<long>();
          } else if (obj.containsKey("id")) {
            resolvedId = obj["id"].as<long>();
          }
        }
      }
      if (resolvedId < 0) {
        apiDeviceId = fetchExistingDeviceId();
      } else {
        apiDeviceId = static_cast<int>(resolvedId);
      }
      return apiDeviceId >= 0;
  }

  // Stellt sicher, dass apiDeviceId gesetzt ist (entweder wiederverwenden oder neu erstellen)
  bool ensureDeviceRegistered() {
      if (apiDeviceId >= 0) return true;
      apiDeviceId = fetchExistingDeviceId();
      if (apiDeviceId >= 0) {
          Serial.printf("Device %s gibt es schon, verwende id %d\n", apiDeviceName, apiDeviceId);
          return true;
      }
      if (createDeviceRecord()) {
          Serial.printf("Device %s erstellt id %d\n", apiDeviceName, apiDeviceId);
          return true;
      }
      Serial.println("Device registrierung fehlgeschlagen");
      return false;
  }

